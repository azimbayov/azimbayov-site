---
import Base from '../layouts/Base.astro';
import { t, categoryLabels } from '../i18n/ui.js';
import { products, allCategories } from '../content/products.js';

export interface Props { lang: 'az' | 'en' | 'tr'; }
const { lang } = Astro.props;

const seoTitle = `${t(lang, 'tpl.h1')} — azimbayov.com`;
const seoDesc = t(lang, 'tpl.lead').slice(0, 160);

// Compute counts per category (client filter still lives in JS below).
const counts: Record<string, number> = { all: products.length };
for (const c of allCategories) counts[c] = products.filter(p => p.cats.includes(c)).length;

// Inline SVG icons for product cards — small, brand-consistent.
const ICONS: Record<string, string> = {
  s5aud: `<svg viewBox="0 0 320 200"><g>${[0,1,2,3,4].map(i=>{
    const x=30+i*52,y=70,sq=45;
    return `<rect x="${x}" y="${y}" width="${sq}" height="${sq*0.92}" rx="5" fill="#fff" stroke="#2CA6A4" stroke-width="2"/>
    <text x="${x+9}" y="${y+27}" font-family="Inter" font-weight="800" font-size="18" fill="#1F4E79">${i+1}S</text>
    <path d="M ${x+34} ${y+22} L ${x+38} ${y+30} L ${x+44} ${y+16}" stroke="#2CA6A4" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>`;
  }).join('')}</g></svg>`,
  gform: `<svg viewBox="0 0 320 200">
    <rect x="115" y="30" width="90" height="140" rx="8" fill="#fff" stroke="#2CA6A4" stroke-width="2"/>
    <rect x="140" y="20" width="40" height="18" rx="4" fill="#1F4E79"/>
    ${[0,1,2,3,4].map(i=>`<rect x="130" y="${52+i*18}" width="${i%2?52:65}" height="4" rx="2" fill="#E3E8EF"/>`).join('')}
    <path d="M 130 148 L 185 148" stroke="#2CA6A4" stroke-width="2.5" stroke-linecap="round"/>
    <path d="M 178 143 L 185 148 L 178 153" stroke="#2CA6A4" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>`,
  gproc: `<svg viewBox="0 0 320 200">
    <rect x="105" y="30" width="110" height="140" rx="8" fill="#fff" stroke="#2CA6A4" stroke-width="2"/>
    <rect x="105" y="30" width="110" height="22" rx="8" fill="#1F4E79"/>
    <rect x="105" y="43" width="110" height="9" fill="#1F4E79"/>
    ${['R','A','C'].map((l,i)=>`
      <rect x="${118+i*30}" y="65" width="24" height="18" rx="3" fill="#EAF6F6" stroke="#2CA6A4" stroke-width="1"/>
      <text x="${130+i*30}" y="79" text-anchor="middle" font-family="Inter" font-weight="700" font-size="11" fill="#1F4E79">${l}</text>
    `).join('')}
    ${[0,1,2,3].map(i=>`
      <circle cx="120" cy="${105+i*15}" r="3.5" fill="#2CA6A4"/>
      <rect x="132" y="${102+i*15}" width="68" height="6" rx="3" fill="#F5F7FA"/>
    `).join('')}
  </svg>`,
  s5proc: `<svg viewBox="0 0 320 200"><g>${[0,1,2,3,4].map(i=>{
    const cx=45+i*57,cy=100,r=22;
    return `${i<4?`<line x1="${cx+r}" y1="${cy}" x2="${cx+57-r}" y2="${cy}" stroke="#2CA6A4" stroke-width="2"/>
    <path d="M ${cx+57-r-6} ${cy-4} L ${cx+57-r} ${cy} L ${cx+57-r-6} ${cy+4}" stroke="#2CA6A4" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>`:''}
    <circle cx="${cx}" cy="${cy}" r="${r}" fill="#fff" stroke="#1F4E79" stroke-width="2"/>
    <text x="${cx}" y="${cy+5}" text-anchor="middle" font-family="Inter" font-weight="800" font-size="15" fill="#1F4E79">${i+1}S</text>`;
  }).join('')}</g></svg>`,
  oproc: `<svg viewBox="0 0 320 200">
    <circle cx="160" cy="100" r="55" fill="#2CA6A4"/>
    <circle cx="160" cy="100" r="41" fill="#fff"/>
    <text x="160" y="98" text-anchor="middle" font-family="Inter" font-weight="800" font-size="20" fill="#1F4E79">OEE</text>
    <text x="160" y="115" text-anchor="middle" font-family="JetBrains Mono" font-weight="500" font-size="9" fill="#5B6B7B">A × P × Q</text>
    ${['A','P','Q'].map((l,i)=>{
      const ang=-Math.PI/2+i*Math.PI*2/3;
      const dx=160+Math.cos(ang)*70,dy=100+Math.sin(ang)*70;
      return `<circle cx="${dx}" cy="${dy}" r="13" fill="#1F4E79"/>
      <text x="${dx}" y="${dy+5}" text-anchor="middle" font-family="Inter" font-weight="800" font-size="13" fill="#fff">${l}</text>`;
    }).join('')}
  </svg>`,
  oxlsx: `<svg viewBox="0 0 320 200">
    <rect x="70" y="40" width="180" height="130" rx="6" fill="#fff" stroke="#2CA6A4" stroke-width="2"/>
    <rect x="70" y="40" width="180" height="20" fill="#1F4E79"/>
    ${[1,2,3].map(i=>`<line x1="${70+i*45}" y1="40" x2="${70+i*45}" y2="170" stroke="#F5F7FA" stroke-width="1"/>`).join('')}
    ${[1,2,3,4].map(i=>`<line x1="70" y1="${60+i*22}" x2="250" y2="${60+i*22}" stroke="#F5F7FA" stroke-width="1"/>`).join('')}
    <text x="85" y="80" font-family="JetBrains Mono" font-weight="500" font-size="10" fill="#1F4E79">OEE %</text>
    ${[0.35,0.5,0.62,0.75,0.85].map((v,i)=>{
      const bx=170+i*14,bh=70*v;
      return `<rect x="${bx}" y="${160-bh}" width="10" height="${bh}" rx="1.5" fill="#2CA6A4"/>`;
    }).join('')}
  </svg>`,
};

const typeKey = (tp: string) =>
  tp === 'template' ? 'tpl.type_template'
  : tp === 'procedure' ? 'tpl.type_procedure'
  : 'tpl.type_workbook';
---

<Base lang={lang} active="templates" title={seoTitle} description={seoDesc} pageKey="templates">
  <section class="pagehero">
    <div class="pagehero-grid" aria-hidden="true"></div>
    <div class="wrap">
      <span class="eyebrow">{t(lang, 'tpl.eyebrow')}</span>
      <h1>{t(lang, 'tpl.h1')}</h1>
      <p>{t(lang, 'tpl.lead')}</p>
    </div>
  </section>

  <section class="block plain">
    <div class="wrap">
      <div class="cat-label">{t(lang, 'tpl.cat_label')}</div>
      <div class="cat-bar" id="catbar">
        <span class="cat on" data-cat="all">{t(lang, 'tpl.cat_all')}<span class="n">{counts.all}</span></span>
        {allCategories.map(c => (
          <span class="cat" data-cat={c}>{categoryLabels[lang][c]}<span class="n">{counts[c]}</span></span>
        ))}
      </div>

      <div class="grid-prod" id="grid">
        {products.map(p => {
          const tr = p.translations[lang];
          return (
            <div class="prod" data-cats={p.cats.join(',')}>
              <div class="thumb" set:html={ICONS[p.id]}>
              </div>
              <div class="thumb-overlay" style="position:absolute;">
              </div>
              <div class="tags" style="position:absolute;top:12px;left:12px;display:flex;gap:5px;flex-wrap:wrap;max-width:80%;">
                {p.cats.slice(0,3).map(c => <span style="font-family:'JetBrains Mono',monospace;font-size:9.5px;letter-spacing:.05em;background:#1F4E79;color:#fff;padding:3px 7px;border-radius:5px;font-weight:500;">{categoryLabels[lang][c]}</span>)}
              </div>
              <div class="fmt" style="position:absolute;top:12px;right:12px;font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.1em;background:#fff;border:1px solid var(--grey-line);color:var(--blue);padding:4px 8px;border-radius:5px;font-weight:500;">{p.format}</div>
              <div class="body">
                <div class="type">{t(lang, typeKey(p.type))}</div>
                <h4>{tr.h}</h4>
                <p>{tr.p}</p>
                <div class="buyrow">
                  <span class="checkout-note">{t(lang, 'tpl.checkout_note')}</span>
                  <a href={p.gumroad} target="_blank" rel="noopener" class="btn btn-teal">{t(lang, 'tpl.buy')}</a>
                </div>
              </div>
            </div>
          );
        })}
        <div class="empty" id="empty" style="display:none;">{t(lang, 'tpl.empty')}</div>
      </div>
    </div>
  </section>

  <section class="trust">
    <div class="wrap trust-grid">
      <div class="trust-item">
        <div class="ic">$</div>
        <div><b>{t(lang, 'tpl.trust1_h')}</b><p>{t(lang, 'tpl.trust1_p')}</p></div>
      </div>
      <div class="trust-item">
        <div class="ic">↓</div>
        <div><b>{t(lang, 'tpl.trust2_h')}</b><p>{t(lang, 'tpl.trust2_p')}</p></div>
      </div>
      <div class="trust-item">
        <div class="ic">✓</div>
        <div><b>{t(lang, 'tpl.trust3_h')}</b><p>{t(lang, 'tpl.trust3_p')}</p></div>
      </div>
    </div>
  </section>

  <script>
    // Simple client-side filter — hide products not matching the picked category.
    const catbar = document.getElementById('catbar');
    const grid = document.getElementById('grid');
    const emptyEl = document.getElementById('empty');
    if (catbar && grid) {
      catbar.addEventListener('click', (e) => {
        const target = e.target.closest('.cat');
        if (!target) return;
        catbar.querySelectorAll('.cat').forEach(c => c.classList.remove('on'));
        target.classList.add('on');
        const cat = target.dataset.cat;
        let visible = 0;
        grid.querySelectorAll('.prod').forEach(el => {
          const cats = (el.dataset.cats || '').split(',');
          const show = cat === 'all' || cats.includes(cat);
          el.style.display = show ? '' : 'none';
          if (show) visible++;
        });
        if (emptyEl) emptyEl.style.display = visible === 0 ? '' : 'none';
      });
    }
  </script>
</Base>
