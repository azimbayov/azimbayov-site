---
// HomePage.astro — the whole homepage content, driven by the current language.
// One template used by /az, /en, /tr — no duplicated markup.
import Base from '../layouts/Base.astro';
import { t } from '../i18n/ui.js';
import { getCollection } from 'astro:content';
import { categoryLabels } from '../i18n/ui.js';

export interface Props { lang: 'az' | 'en' | 'tr'; }
const { lang } = Astro.props;

const base = `/${lang}`;
const seoTitle = `azimbayov.com — ${t(lang, 'home.eyebrow')}`;
const seoDesc = t(lang, 'home.lead').slice(0, 160);

// Latest 3 blog posts (EN only for now — that's where posts live).
const allPosts = await getCollection('blog', ({ data }) =>
  data.lang === 'en' && data.draft !== true
);
allPosts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
const latestPosts = allPosts.slice(0, 3);

const fmtDate = (d: Date) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---

<Base lang={lang} active="home" title={seoTitle} description={seoDesc} pageKey="home">
  <!-- HERO -->
  <section class="hero">
    <div class="hero-grid" aria-hidden="true"></div>
    <div class="wrap hero-inner">
      <div>
        <span class="eyebrow">{t(lang, 'home.eyebrow')}</span>
        <h1>{t(lang, 'home.h1_a')} <span style="color:var(--teal);">{t(lang, 'home.h1_b')}</span></h1>
        <p class="lead">{t(lang, 'home.lead')}</p>
        <div class="hero-cta">
          <a class="btn btn-primary" href={`${base}/templates/`}>{t(lang, 'home.cta_templates')}</a>
          <a class="btn btn-ghost" href={`${base}/consulting/`}>{t(lang, 'home.cta_work')}</a>
        </div>
        <div class="metrics">
          <div class="metric"><b>+4</b><small>{t(lang, 'home.metric1')}</small></div>
          <div class="metric"><b>−38%</b><small>{t(lang, 'home.metric2')}</small></div>
          <div class="metric"><b>326</b><small>{t(lang, 'home.metric3')}</small></div>
        </div>
        <div class="metric-cap">{t(lang, 'home.metric_caption')}</div>
      </div>
      <div class="portrait">
        <div class="frame">
          <div class="ph">
            <picture>
              <source srcset="/images/portrait.webp" type="image/webp" />
              <img src="/images/portrait-fallback.jpg" alt={t(lang, 'home.portrait_role')} width="800" height="800" loading="eager" fetchpriority="high" decoding="async" />
            </picture>
          </div>
        </div>
        <div class="tag">
          <b>{lang === 'az' ? 'Ərtoğrul Əzimbəyov' : lang === 'tr' ? 'Ertuğrul Azimbayov' : 'Artoghrul Azimbayov'}</b>
          <small>{t(lang, 'home.portrait_role')}</small>
        </div>
      </div>
    </div>
  </section>

  <!-- WHAT I WORK WITH -->
  <section class="block alt">
    <div class="wrap">
      <span class="eyebrow">{t(lang, 'home.work_eyebrow')}</span>
      <div class="strip">
        <span class="chip">5S</span>
        <span class="chip">Kaizen</span>
        <span class="chip">OEE</span>
        <span class="chip">RCA</span>
        <span class="chip">SMED</span>
        <span class="chip">Poka-Yoke</span>
        <span class="chip">PDCA</span>
        <span class="chip">Gemba Walk</span>
        <span class="chip">API 5L · EN 10219</span>
      </div>
    </div>
  </section>

  <!-- TWO WAYS -->
  <section class="block">
    <div class="wrap">
      <div class="sec-head">
        <span class="eyebrow">{t(lang, 'home.ways_eyebrow')}</span>
        <h2>{t(lang, 'home.ways_h')}</h2>
        <p>{t(lang, 'home.ways_sub')}</p>
      </div>
      <div class="grid3">
        <a class="card" href={`${base}/templates/`}>
          <span class="num">01</span>
          <h3>{t(lang, 'home.c1_h')}</h3>
          <p>{t(lang, 'home.c1_p')}</p>
          <span class="arrow">{t(lang, 'home.c1_a')}</span>
        </a>
        <a class="card" href={`${base}/consulting/`}>
          <span class="num">02</span>
          <h3>{t(lang, 'home.c2_h')}</h3>
          <p>{t(lang, 'home.c2_p')}</p>
          <span class="arrow">{t(lang, 'home.c2_a')}</span>
        </a>
        <a class="card" href={`${base}/about/`}>
          <span class="num">03</span>
          <h3>{t(lang, 'home.c3_h')}</h3>
          <p>{t(lang, 'home.c3_p')}</p>
          <span class="arrow">{t(lang, 'home.c3_a')}</span>
        </a>
      </div>
    </div>
  </section>

  {latestPosts.length > 0 && (
    <!-- LATEST FROM BLOG -->
    <section class="block plain">
      <div class="wrap">
        <div class="sec-head sec-head-row">
          <div>
            <span class="eyebrow">{t(lang, 'home.blog_eyebrow')}</span>
            <h2>{t(lang, 'home.blog_h')}</h2>
            <p>{t(lang, 'home.blog_sub')}</p>
          </div>
          <a class="blog-all-link" href="/en/blog/">{t(lang, 'home.blog_all')}</a>
        </div>

        <div class="home-blog-grid">
          {latestPosts.map(post => (
            <a href={`/en/blog/${post.slug.split('/').pop()}/`} class="home-blog-card">
              <div class="home-blog-meta">
                <span class="home-blog-cat">{categoryLabels['en'][post.data.category]}</span>
                <span class="home-blog-date">{fmtDate(post.data.pubDate)}</span>
              </div>
              <h3>{post.data.title}</h3>
              <p>{post.data.description}</p>
              <span class="home-blog-more">{t(lang, 'home.blog_read')}</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</Base>

<style>
  .sec-head-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 24px;
    flex-wrap: wrap;
  }
  .blog-all-link {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: var(--teal);
    text-decoration: none;
    font-weight: 600;
    letter-spacing: .04em;
    white-space: nowrap;
  }
  .blog-all-link:hover { text-decoration: underline; }

  .home-blog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-top: 32px;
  }
  @media (max-width: 900px) { .home-blog-grid { grid-template-columns: 1fr; } }

  .home-blog-card {
    display: flex;
    flex-direction: column;
    background: #fff;
    border: 1px solid var(--grey-line);
    border-radius: 10px;
    padding: 22px 24px 24px;
    text-decoration: none;
    color: inherit;
    transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease;
  }
  .home-blog-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 6px 20px rgba(31, 78, 121, .08);
    border-color: var(--teal);
  }
  .home-blog-meta {
    display: flex;
    gap: 10px;
    align-items: center;
    margin-bottom: 12px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: .06em;
    text-transform: uppercase;
  }
  .home-blog-cat {
    background: #EAF6F6;
    color: var(--blue);
    padding: 3px 8px;
    border-radius: 4px;
    font-weight: 600;
  }
  .home-blog-date { color: var(--muted); }
  .home-blog-card h3 {
    font-size: 17px;
    line-height: 1.35;
    color: var(--blue);
    margin: 0 0 8px;
    font-weight: 700;
  }
  .home-blog-card p {
    color: var(--muted);
    font-size: 14px;
    line-height: 1.55;
    margin: 0 0 14px;
    flex: 1;
  }
  .home-blog-more {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--teal);
    font-weight: 600;
    letter-spacing: .04em;
  }
</style>
