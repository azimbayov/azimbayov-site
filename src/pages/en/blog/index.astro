---
// Blog list page — /en/blog/
// Lists every published English post, sorted by publish date descending.
import Base from '../../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { categoryLabels } from '../../../i18n/ui.js';

const lang = 'en' as const;

// Grab all EN posts, drop drafts, sort newest first.
const allPosts = await getCollection('blog', ({ data }) =>
  data.lang === lang && data.draft !== true
);
allPosts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const seoTitle = 'Blog — Lean, CI & Kaizen from a real factory floor · azimbayov.com';
const seoDesc = 'Practical notes on Lean, Continuous Improvement, 5S, OEE and Kaizen — written from a live steel pipe plant, not a textbook.';

// Format publish date as "Jul 5, 2026".
const fmtDate = (d: Date) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---

<Base lang={lang} title={seoTitle} description={seoDesc}>
  <section class="pagehero">
    <div class="pagehero-grid" aria-hidden="true"></div>
    <div class="wrap">
      <span class="eyebrow">Blog</span>
      <h1>Notes from the factory floor.</h1>
      <p>Practical Lean, CI and Kaizen — what worked, what failed, and the templates you can steal. Written between shifts, not in a classroom.</p>
    </div>
  </section>

  <section class="block plain">
    <div class="wrap">
      {allPosts.length === 0 ? (
        <p style="color: var(--muted); font-size: 17px;">No posts yet — check back soon.</p>
      ) : (
        <div class="blog-list">
          {allPosts.map(post => (
            <a href={`/en/blog/${post.slug.split('/').pop()}/`} class="blog-card">
              {post.data.cover && (
                <div class="blog-card-cover">
                  <img src={post.data.cover} alt={post.data.coverAlt || ''} loading="lazy" />
                </div>
              )}
              <div class="blog-card-body">
                <div class="blog-card-meta">
                  <span class="blog-card-cat">{categoryLabels[lang][post.data.category]}</span>
                  <span class="blog-card-date">{fmtDate(post.data.pubDate)}</span>
                </div>
                <h2>{post.data.title}</h2>
                <p>{post.data.description}</p>
                <span class="blog-card-more">Read →</span>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
</Base>

<style>
  .blog-list {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 28px;
  }
  @media (max-width: 780px) {
    .blog-list { grid-template-columns: 1fr; }
  }
  .blog-card {
    display: flex;
    flex-direction: column;
    background: #fff;
    border: 1px solid var(--grey-line);
    border-radius: 10px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease;
  }
  .blog-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 6px 20px rgba(31, 78, 121, .08);
    border-color: var(--teal);
  }
  .blog-card-cover {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: #F5F7FA;
  }
  .blog-card-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .blog-card-body { padding: 22px 24px 26px; }
  .blog-card-meta {
    display: flex;
    gap: 12px;
    align-items: center;
    margin-bottom: 12px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: .06em;
    text-transform: uppercase;
  }
  .blog-card-cat {
    background: #EAF6F6;
    color: var(--blue);
    padding: 4px 9px;
    border-radius: 4px;
    font-weight: 600;
  }
  .blog-card-date { color: var(--muted); }
  .blog-card h2 {
    font-size: 20px;
    line-height: 1.3;
    margin: 0 0 10px;
    color: var(--blue);
    font-weight: 700;
  }
  .blog-card p {
    color: var(--muted);
    font-size: 15px;
    line-height: 1.55;
    margin: 0 0 16px;
  }
  .blog-card-more {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: var(--teal);
    font-weight: 600;
    letter-spacing: .04em;
  }
</style>
